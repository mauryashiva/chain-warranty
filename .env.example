# ===============================
# Database Configuration
# ===============================
# PostgreSQL connection string (Prisma / Supabase / Neon)
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ===============================
# Blockchain / Web3 Configuration
# ===============================
# RPC URL from Alchemy / Infura (Sepolia recommended)
# Example: https://eth-sepolia.g.alchemy.com/v2/your-api-key
RPC_URL=

# Private key of your wallet (used to deploy & mint NFTs)
# ⚠️ NEVER share this or commit it to GitHub
PRIVATE_KEY=

# Deployed smart contract address (after Hardhat deploy)
# Example: 0xABC123...
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Storage & API
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Base URL for frontend API calls (Next.js backend or external API)
NEXT_PUBLIC_API_URL=http://localhost:3000