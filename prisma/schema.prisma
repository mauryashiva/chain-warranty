generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER & AUTHENTICATION
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  name  String?
  email String? @unique
  phone String?

  wallets    Wallet[]
  claims     Claim[]
  warranties WarrantyOwnership[]

  sentTransfers     Transfer[] @relation("FromUser")
  receivedTransfers Transfer[] @relation("ToUser")

  @@index([createdAt])
  @@index([email])
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([address])
}

// ==========================================
// ADMIN & ACCESS CONTROL (RBAC)
// ==========================================

enum AdminRole {
  SUPER_ADMIN
  BRAND_MANAGER
  CLAIMS_AGENT
  RETAILER_MANAGER
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

model Admin {
  id String @id @default(cuid())

  // --- Authentication (MetaMask SIWE) ---
  // Store as lowercase to prevent case-sensitivity login issues
  walletAddress String @unique

  // --- Profile ---
  name      String
  email     String  @unique
  phone     String?
  avatarUrl String?

  // --- Role & Status ---
  role   AdminRole   @default(CLAIMS_AGENT)
  status AdminStatus @default(ACTIVE)

  // --- Permissions Matrix (Directly matches your UI Matrix) ---
  canManageBrands    Boolean @default(false)
  canManageProducts  Boolean @default(false)
  canUploadSerials   Boolean @default(false)
  canManageRetailers Boolean @default(false)
  canReviewClaims    Boolean @default(false)
  canResolveOnChain  Boolean @default(false) // For blockchain transactions
  canManageAdmins    Boolean @default(false)
  canViewAuditLog    Boolean @default(true)

  // --- Security & Session Tracking ---
  twoFAEnabled Boolean   @default(false)
  twoFASecret  String? // Encrypted TOTP secret
  lastLogin    DateTime?
  lastLoginIp  String?
  loginCount   Int       @default(0)

  // --- Accountability ---
  isDeleted Boolean  @default(false)
  createdBy String? // adminId of Super Admin who invited
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relations ---
  auditLogs      AuditLog[]
  // Tracks which claims this admin specifically resolved
  resolvedClaims Claim[]    @relation("AdminResolver")

  @@index([walletAddress])
  @@index([role])
  @@index([status])
  @@index([email])
}

//////////////////////////////////////////////////////
// 🏢 BUSINESS ENTITIES & CATALOG
//////////////////////////////////////////////////////

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  description String?  @db.Text
  logoUrl     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  brands Brand[]

  @@index([name])
}

model Brand {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  country String
  status  BrandStatus @default(ACTIVE)

  website      String?
  supportEmail String?
  supportPhone String?
  taxId        String?
  logoUrl      String?
  description  String? @db.Text

  // Company relation — optional
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  retailers Retailer[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  products Product[]

  @@index([slug])
  @@index([status])
  @@index([companyId])
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String  @id @default(cuid())
  name        String
  modelNumber String
  description String? @db.Text
  category    String?
  subCategory String?
  sku         String? @unique

  // Pricing
  warrantyPeriodMonths Int?
  warrantyPeriod       String?
  priceMin             Float?
  priceMax             Float?
  currency             String? @default("USD")

  // Manufacturing & Compliance
  launchDate         DateTime?
  manufactureCountry String?
  hsnCode            String?
  variants           String?
  serialRegex        String?
  termsUrl           String?

  status    ProductStatus @default(ACTIVE)
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt

  // Brand relation — required
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  warrantyRule WarrantyRule?
  serials      Serial[]
  warranties   Warranty[]
  claims       Claim[]

  @@index([brandId])
  @@index([sku])
  @@index([status])
  @@index([category])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model GlobalConfig {
  id                             String  @id @default(cuid())
  singleton                      String  @unique @default("global") // prevents multiple rows
  // Registration Rules
  allowRegistrationAfterPurchase Boolean @default(true)
  maxDaysToRegister              Int     @default(30)

  // Transfer Rules
  allowTransfer              Boolean @default(true)
  allowTransferWithOpenClaim Boolean @default(false)
  requireOtpForTransfer      Boolean @default(true)
  requireIdProofForTransfer  Boolean @default(false)

  // Lifecycle Rules
  allowClaimAfterExpiry Boolean @default(false)
  autoExpireNft         Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// 2. Specific Overrides for individual Product Models
model WarrantyRule {
  id String @id @default(cuid())

  // Link to the Product
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Coverage Specs
  defaultPeriod  Int @default(12) // Months (e.g. 12, 24, 36)
  extendedPeriod Int @default(0) // Months (Optional addition)

  // Claim Logic
  maxClaimsAllowed  Int @default(3) // Total claims allowed per lifetime
  claimCooldownDays Int @default(30) // Days to wait between two claims

  // Transfer Logic
  isTransferable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// 🔢 SERIAL NUMBERS
//////////////////////////////////////////////////////

model Serial {
  id String @id @default(cuid())

  serialNumber    String    @unique
  batchId         String?
  manufactureDate DateTime?
  dispatchDate    DateTime?

  status    SerialStatus @default(UNREGISTERED)
  isDeleted Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  productId String
  product   Product @relation(fields: [productId], references: [id])

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id])

  // One serial = one warranty (unique)
  warranty Warranty?

  @@index([serialNumber])
  @@index([productId])
  @@index([retailerId])
  @@index([status])
}

enum SerialStatus {
  UNREGISTERED
  REGISTERED
  FLAGGED
  BLOCKED
}

//////////////////////////////////////////////////////
// 🏪 RETAILERS
//////////////////////////////////////////////////////

model Retailer {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  type RetailerType @default(BOTH)

  contactEmail String?
  contactPhone String?
  website      String?

  address String? @db.Text
  city    String?
  state   String?
  pinCode String?
  country String? @default("India")

  gstNumber String? @unique
  taxId     String?
  panNumber String?

  status    RetailerStatus @default(ACTIVE)
  isDeleted Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  serials    Serial[]
  warranties Warranty[]
  brands     Brand[] // ← add this one line

  @@index([slug])
  @@index([status])
  @@index([gstNumber])
}

enum RetailerType {
  ONLINE
  OFFLINE
  BOTH
}

enum RetailerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ==========================================
// CLAIMS MANAGEMENT SYSTEM
// ==========================================

enum ClaimType {
  REPAIR
  REPLACEMENT
  REFUND
}

enum ClaimStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
  CANCELLED
}

enum ClaimPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Claim {
  id          String @id @default(cuid())
  claimNumber String @unique // e.g. CLM-2024-0001

  // ✅ Core Relations
  warrantyId String
  warranty   Warranty @relation(fields: [warrantyId], references: [id])

  productId String // Direct link for easier analytics
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // ✅ Claim Details
  type        ClaimType
  status      ClaimStatus   @default(PENDING)
  priority    ClaimPriority @default(MEDIUM)
  subject     String // e.g. "Left earbud no sound"
  description String        @db.Text

  // ✅ Issue Metadata
  issueDate        DateTime?
  productCondition String? // Physical state of item

  // ✅ Fraud & Risk Scoring
  fraudScore  Float?  @default(0)
  isFraud     Boolean @default(false)
  fraudReason String?

  // ✅ Admin Assignment
  assignedTo String? // Admin ID handling the case
  assignedAt DateTime?

  // ✅ Resolution Tracking
  resolvedAt      DateTime?
  // 1. The ID field (Renamed from resolvedBy to resolvedById)
  resolvedById    String?
  resolvedByAdmin Admin?    @relation("AdminResolver", fields: [resolvedById], references: [id])

  // 2. The Formal Relation (Links to your Admin model)
  resolvedBy     String? // Admin ID
  resolution     String? @db.Text
  resolutionType String? // REPAIRED / REPLACED / REFUNDED
  txHash         String? // Blockchain transaction hash for resolution

  // ✅ Rejection / Cancellation
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text
  cancelledAt     DateTime?
  cancelReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ Related Models
  logs      ClaimLog[]
  documents ClaimDocument[]

  @@index([warrantyId])
  @@index([productId])
  @@index([status])
  @@index([claimNumber])
}

model ClaimLog {
  id      String @id @default(cuid())
  claimId String
  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  status    ClaimStatus
  note      String?     @db.Text
  changedBy String? // adminId or userId
  createdAt DateTime    @default(now())

  @@index([claimId])
}

model ClaimDocument {
  id      String @id @default(cuid())
  claimId String
  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  name       String // e.g. "Cracked screen photo"
  url        String // Cloudinary/Storage URL
  fileType   String // IMAGE / VIDEO / PDF
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([claimId])
}

// ==========================================
// SYSTEM AUDIT & GOVERNANCE
// ==========================================

enum AuditAction {
  BRAND_CREATE
  BRAND_UPDATE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  SERIAL_UPLOAD
  RULE_CHANGE // When Global or SKU policy changes
  CLAIM_STATUS_CHANGE
  RETAILER_ADD
  USER_INVITE
  SYSTEM_CONFIG_CHANGE
}

enum AuditEntity {
  BRAND
  PRODUCT
  SERIAL
  RETAILER
  CLAIM
  WARRANTY_RULE
  GLOBAL_CONFIG
  USER
}

model AuditLog {
  id String @id @default(cuid())

  // 👤 The Admin
  adminId    String
  admin      Admin  @relation(fields: [adminId], references: [id]) // ✅ ADD THIS RELATION
  adminName  String // Denormalized for fast reading in logs
  adminEmail String

  // 🛠️ The Action
  action     AuditAction
  entity     AuditEntity
  entityId   String? // ID of the Brand, Product, or Claim affected
  entityName String? // Name of the entity (e.g., "Sony" or "CLM-003")

  // 📝 Details
  details  String @db.Text // Human readable e.g., "Updated warranty from 12 to 24 months"
  oldValue Json? // Snapshot of data before change
  newValue Json? // Snapshot of data after change

  // 🔗 Blockchain Context
  txHash    String? // If the action involved an on-chain event
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// 🧾 WARRANTY CORE (BLOCKCHAIN LINKED)
//////////////////////////////////////////////////////

model Warranty {
  id String @id @default(cuid())

  // Blockchain data
  tokenId         String  @unique
  contractAddress String
  ownerWallet     String?
  ipfsMetadataUrl String?
  txHash          String?
  blockNumber     Int?
  chainId         Int?    @default(137) // 137 = Polygon Mainnet

  // Product snapshot — frozen at registration time
  productName      String?
  brand            String?
  modelNumber      String
  category         String?
  subCategory      String?
  color            String?
  productCondition String?
  imei             String?
  serialNumber     String? // snapshot copy — source of truth is Serial.serialNumber

  // Purchase details
  purchaseDate   DateTime
  expiryDate     DateTime
  warrantyPeriod String?
  price          Decimal? @db.Decimal(10, 2)
  invoiceNumber  String?
  currency       String?  @default("USD")
  retailerName   String? // Snapshot of retailer name
  country        String?

  // Owner snapshot at registration time
  ownerName  String?
  ownerEmail String?
  ownerPhone String?

  // Media — Cloudinary / Supabase URLs
  frontPhotoUrl   String?
  backPhotoUrl    String?
  invoiceDocUrl   String?
  warrantyCardUrl String?

  // QR code
  qrCodeUrl String?

  // Status
  status    WarrantyStatus @default(ACTIVE)
  isDeleted Boolean        @default(false)

  // ─── Claim Counter ───────────────────────────────────
  // Incremented on every new claim filed
  // Checked against WarrantyRule.maxClaimsAllowed
  totalClaimsFiled Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core relations
  productId String
  product   Product @relation(fields: [productId], references: [id])

  serialId String? @unique
  serial   Serial? @relation(fields: [serialId], references: [id])

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id])

  // Activity relations
  ownerships WarrantyOwnership[]
  claims     Claim[]
  events     WarrantyEvent[]
  transfers  Transfer[]

  @@index([tokenId])
  @@index([ownerWallet])
  @@index([serialId])
  @@index([productId])
  @@index([status])
  @@index([ownerEmail])
  @@index([expiryDate])
  @@index([purchaseDate])
  @@index([createdAt])
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  TRANSFERRED
  VOIDED
}

//////////////////////////////////////////////////////
// 👑 OWNERSHIP & TRANSFERS
//////////////////////////////////////////////////////

model WarrantyOwnership {
  id         String   @id @default(cuid())
  warrantyId String
  userId     String
  isActive   Boolean  @default(true)
  fromWallet String? // wallet at time of receiving
  toWallet   String? // wallet transferred to
  acquiredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  // Transfer context — null for original registration
  transferReason String?
  salePrice      Decimal? @db.Decimal(10, 2)

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([warrantyId, userId])
  @@index([warrantyId])
  @@index([userId])
  @@index([isActive])
}

// Created for every lifecycle event — full audit trail
model WarrantyEvent {
  id         String @id @default(cuid())
  warrantyId String

  type        EventType
  txHash      String? // On-chain tx if applicable
  metadata    Json? // Any extra context as JSON
  triggeredBy String? // userId or adminId

  createdAt DateTime @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])

  @@index([warrantyId])
  @@index([type])
  @@index([createdAt])
}

enum EventType {
  REGISTERED // NFT minted — warranty created
  CLAIM_INITIATED // User filed a claim
  CLAIM_APPROVED // Admin approved claim
  CLAIM_REJECTED // Admin rejected claim
  CLAIM_RESOLVED // Admin resolved and closed claim
  TRANSFERRED // Ownership transferred to new owner
  EXPIRED // Warranty crossed expiry date
  VOIDED // Admin manually voided warranty
  DOCUMENT_UPDATED // User re-uploaded a document
}

model Transfer {
  id         String         @id @default(cuid())
  warrantyId String
  fromUserId String
  toUserId   String
  txHash     String         @unique
  status     TransferStatus @default(PENDING)

  // Transfer details
  fromWallet   String?
  toWallet     String?
  reason       String? // SOLD, GIFT, INHERITED etc
  salePrice    Decimal?  @db.Decimal(10, 2)
  transferDate DateTime?

  // ID verification
  idType   String?
  idNumber String?

  // Document proof
  saleAgreementUrl String?
  idPhotoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  fromUser User     @relation("FromUser", fields: [fromUserId], references: [id])
  toUser   User     @relation("ToUser", fields: [toUserId], references: [id])

  @@index([warrantyId])
  @@index([txHash])
  @@index([status])
  @@index([fromUserId])
  @@index([toUserId])
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
  REJECTED
}
