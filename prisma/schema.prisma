generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER & AUTHENTICATION
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  // Profile info from registration
  name      String?
  email     String?  @unique
  phone     String?

  wallets    Wallet[]
  claims     Claim[]
  warranties WarrantyOwnership[]

  sentTransfers     Transfer[] @relation("FromUser")
  receivedTransfers Transfer[] @relation("ToUser")

  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  userId    String
  createdAt DateTime @default(now())

  // 🔥 Industry Fix: Added Cascade Delete so no orphan wallets remain if a User is removed
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address]) 
  @@index([address])
}

//////////////////////////////////////////////////////
// 🏢 BUSINESS ENTITIES
//////////////////////////////////////////////////////

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  createdAt DateTime  @default(now())
  isDeleted Boolean   @default(false)
  products  Product[]
}

model Product {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String?    
  companyId   String
  createdAt   DateTime   @default(now())
  isDeleted   Boolean    @default(false)

  company    Company    @relation(fields: [companyId], references: [id])
  warranties Warranty[]

  @@index([companyId])
}

//////////////////////////////////////////////////////
// 🧾 WARRANTY CORE (BLOCKCHAIN LINKED)
//////////////////////////////////////////////////////

model Warranty {
  id              String   @id @default(cuid())
  tokenId         String   @unique
  contractAddress String

  // Data captured from Step 01 & 03
  productName      String?
  brand            String?
  serialNumber     String?
  imei             String?
  category         String?
  color            String?
  productCondition String? 
  
  // Purchase Details
  purchaseDate     DateTime
  warrantyPeriod   String?
  expiryDate       DateTime
  
  // 🔥 Industry Fix: Decimal is the gold standard for currency to avoid rounding errors
  price            Decimal? @db.Decimal(10, 2) 
  
  retailer         String?
  invoiceNumber    String?
  country          String?

  // Original Registrant Info (Snapshot for legal/history)
  ownerName        String?
  ownerEmail       String?
  ownerPhone       String?

  // Cloud Storage Links (Supabase URLs)
  frontPhotoUrl    String?
  backPhotoUrl     String?
  invoiceDocUrl    String?
  warrantyCardUrl  String?

  status           WarrantyStatus @default(ACTIVE)
  qrCodeUrl        String?
  
  productId        String
  product          Product        @relation(fields: [productId], references: [id])

  // Relations
  ownerships       WarrantyOwnership[]
  claims           Claim[]
  events           WarrantyEvent[]
  transfers        Transfer[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isDeleted        Boolean  @default(false)

  @@index([tokenId])
  // 🔥 Industry Fix: Optimized for "Brand + Serial" lookups
  @@index([brand, serialNumber]) 
  @@index([ownerEmail])
}

//////////////////////////////////////////////////////
// 👑 OWNERSHIP & TRANSFERS
//////////////////////////////////////////////////////

model WarrantyOwnership {
  id          String   @id @default(cuid())
  warrantyId  String
  userId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warranty    Warranty @relation(fields: [warrantyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([warrantyId, userId])
  @@index([warrantyId])
  @@index([userId])
}

model Transfer {
  id          String   @id @default(cuid())
  warrantyId  String
  fromUserId  String
  toUserId    String
  txHash      String   @unique
  createdAt   DateTime @default(now())

  warranty    Warranty @relation(fields: [warrantyId], references: [id])
  fromUser    User     @relation("FromUser", fields: [fromUserId], references: [id])
  toUser      User     @relation("ToUser", fields: [toUserId], references: [id])

  @@index([warrantyId])
  @@index([txHash])
}

//////////////////////////////////////////////////////
// 🛠️ CLAIM SYSTEM
//////////////////////////////////////////////////////

model Claim {
  id          String      @id @default(cuid())
  warrantyId  String
  userId      String
  type        ClaimType
  status      ClaimStatus @default(PENDING)
  reason      String?
  fraudScore  Float?
  isFraud     Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  warranty    Warranty    @relation(fields: [warrantyId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  logs        ClaimLog[]

  @@index([warrantyId])
  @@index([userId])
}

model ClaimLog {
  id        String      @id @default(cuid())
  claimId   String
  status    ClaimStatus
  note      String?
  createdAt DateTime    @default(now())

  claim     Claim       @relation(fields: [claimId], references: [id])
}

model WarrantyEvent {
  id          String    @id @default(cuid())
  warrantyId  String
  type        EventType
  txHash      String?
  metadata    Json?     
  createdAt   DateTime  @default(now())

  warranty    Warranty  @relation(fields: [warrantyId], references: [id])

  @@index([warrantyId])
}

//////////////////////////////////////////////////////
// 📊 ENUMS
//////////////////////////////////////////////////////

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
}

enum ClaimType {
  REPAIR
  REPLACEMENT
  REFUND
}

enum EventType {
  CREATED
  TRANSFERRED
  CLAIM_INITIATED
  CLAIM_APPROVED
  CLAIM_REJECTED
  EXPIRED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
}