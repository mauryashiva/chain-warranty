generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER & AUTHENTICATION
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  name  String?
  email String? @unique
  phone String?

  wallets    Wallet[]
  claims     Claim[]
  warranties WarrantyOwnership[]

  sentTransfers     Transfer[] @relation("FromUser")
  receivedTransfers Transfer[] @relation("ToUser")

  @@index([createdAt])
  @@index([email])
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([address])
}

//////////////////////////////////////////////////////
// 🔐 ADMIN & RBAC SYSTEM
//////////////////////////////////////////////////////

model Admin {
  id        String      @id @default(cuid())
  wallet    String      @unique
  name      String
  email     String      @unique
  role      AdminRole   @default(CLAIMS_AGENT)
  status    AdminStatus @default(ACTIVE)
  twoFAEnabled Boolean  @default(false)
  lastLogin DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt

  auditLogs AuditLog[]

  @@index([wallet])
  @@index([role])
  @@index([status])
}

enum AdminRole {
  SUPER_ADMIN
  BRAND_MANAGER
  CLAIMS_AGENT
  RETAILER_MANAGER
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

//////////////////////////////////////////////////////
// 🏢 BUSINESS ENTITIES & CATALOG
//////////////////////////////////////////////////////

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  description String?  @db.Text
  logoUrl     String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  brands Brand[]

  @@index([name])
}

model Brand {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  country     String
  status      BrandStatus @default(ACTIVE)

  website      String?
  supportEmail String?
  supportPhone String?
  taxId        String?
  logoUrl      String?
  description  String? @db.Text

  // Company relation — optional
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  retailers Retailer[]

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  products Product[]

  @@index([slug])
  @@index([status])
  @@index([companyId])
}

enum BrandStatus {
  ACTIVE
  INACTIVE
}

model Product {
  id          String  @id @default(cuid())
  name        String
  modelNumber String
  description String? @db.Text
  category    String?
  subCategory String?
  sku         String? @unique

  // Pricing
  warrantyPeriodMonths Int?
  warrantyPeriod       String?
  priceMin             Float?
  priceMax             Float?
  currency             String? @default("USD")

  // Manufacturing & Compliance
  launchDate         DateTime?
  manufactureCountry String?
  hsnCode            String?
  variants           String?
  serialRegex        String?
  termsUrl           String?

  status    ProductStatus @default(ACTIVE)
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt

  // Brand relation — required
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  serials    Serial[]
  warranties Warranty[]

  @@index([brandId])
  @@index([sku])
  @@index([status])
  @@index([category])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

//////////////////////////////////////////////////////
// 🔢 SERIAL NUMBERS
//////////////////////////////////////////////////////

model Serial {
  id String @id @default(cuid())

  serialNumber    String    @unique
  batchId         String?
  manufactureDate DateTime?
  dispatchDate    DateTime?

  status    SerialStatus @default(UNREGISTERED)
  isDeleted Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  productId  String
  product    Product   @relation(fields: [productId], references: [id])

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id])

  // One serial = one warranty (unique)
  warranty   Warranty? 

  @@index([serialNumber])
  @@index([productId])
  @@index([retailerId])
  @@index([status])
}

enum SerialStatus {
  UNREGISTERED
  REGISTERED
  FLAGGED
  BLOCKED
}

//////////////////////////////////////////////////////
// 🏪 RETAILERS
//////////////////////////////////////////////////////

model Retailer {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  type RetailerType @default(BOTH)
  
  

  contactEmail String?
  contactPhone String?
  website      String?

  address String? @db.Text
  city    String?
  state   String?
  pinCode String?
  country String? @default("India")

  gstNumber String? @unique
  taxId     String?
  panNumber String?

  status    RetailerStatus @default(ACTIVE)
  isDeleted Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  serials    Serial[]
  warranties Warranty[]
  brands Brand[] // ← add this one line


  @@index([slug])
  @@index([status])
  @@index([gstNumber])
}

enum RetailerType {
  ONLINE
  OFFLINE
  BOTH
}

enum RetailerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

//////////////////////////////////////////////////////
// 🧾 WARRANTY CORE (BLOCKCHAIN LINKED)
//////////////////////////////////////////////////////

model Warranty {
  id String @id @default(cuid())

  // Blockchain data
  tokenId         String  @unique
  contractAddress String
  ownerWallet     String?
  ipfsMetadataUrl String?
  txHash          String?
  blockNumber     Int?
  chainId         Int?    @default(137) // 137 = Polygon Mainnet

  // Product snapshot — frozen at registration time
  productName      String?
  brand            String?
  category         String?
  color            String?
  productCondition String?
  imei             String?
  serialNumber     String? // snapshot copy — source of truth is Serial.serialNumber

  // Purchase details
  purchaseDate   DateTime
  warrantyPeriod String?
  expiryDate     DateTime
  price          Decimal? @db.Decimal(10, 2)
  invoiceNumber  String?
  country        String?

  // Owner snapshot at registration time
  ownerName  String?
  ownerEmail String?
  ownerPhone String?

  // Media — Cloudinary / Supabase URLs
  frontPhotoUrl   String?
  backPhotoUrl    String?
  invoiceDocUrl   String?
  warrantyCardUrl String?

  // QR code
  qrCodeUrl String?

  // Status
  status    WarrantyStatus @default(ACTIVE)
  isDeleted Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core relations
  productId String
  product   Product @relation(fields: [productId], references: [id])

  serialId String?  @unique
  serial   Serial?  @relation(fields: [serialId], references: [id])

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id])

  // Activity relations
  ownerships WarrantyOwnership[]
  claims     Claim[]
  events     WarrantyEvent[]
  transfers  Transfer[]

  @@index([tokenId])
  @@index([ownerWallet])
  @@index([serialId])
  @@index([status])
  @@index([ownerEmail])
  @@index([productId])
  @@index([expiryDate])
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  TRANSFERRED
  VOIDED
}

//////////////////////////////////////////////////////
// 👑 OWNERSHIP & TRANSFERS
//////////////////////////////////////////////////////

model WarrantyOwnership {
  id         String   @id @default(cuid())
  warrantyId String
  userId     String
  isActive   Boolean  @default(true)
  fromWallet String?  // wallet at time of receiving
  toWallet   String?  // wallet transferred to
  acquiredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([warrantyId, userId])
  @@index([warrantyId])
  @@index([userId])
  @@index([isActive])
}

model Transfer {
  id         String         @id @default(cuid())
  warrantyId String
  fromUserId String
  toUserId   String
  txHash     String         @unique
  status     TransferStatus @default(PENDING)

  // Transfer details
  fromWallet    String?
  toWallet      String?
  reason        String?  // SOLD, GIFT, INHERITED etc
  salePrice     Decimal? @db.Decimal(10, 2)
  transferDate  DateTime?

  // ID verification
  idType   String?
  idNumber String?

  // Document proof
  saleAgreementUrl String?
  idPhotoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  fromUser User     @relation("FromUser", fields: [fromUserId], references: [id])
  toUser   User     @relation("ToUser", fields: [toUserId], references: [id])

  @@index([warrantyId])
  @@index([txHash])
  @@index([status])
  @@index([fromUserId])
  @@index([toUserId])
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
  REJECTED
}

//////////////////////////////////////////////////////
// 🛠️ CLAIM SYSTEM
//////////////////////////////////////////////////////

model Claim {
  id         String      @id @default(cuid())
  warrantyId String
  userId     String
  type       ClaimType
  status     ClaimStatus @default(PENDING)
  reason     String?     @db.Text
  fraudScore Float?
  isFraud    Boolean     @default(false)

  // Resolution details
  resolvedAt  DateTime?
  resolvedBy  String?   // adminId who resolved
  resolution  String?   @db.Text
  txHash      String?   // on-chain resolution hash

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warranty Warranty   @relation(fields: [warrantyId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  logs     ClaimLog[]

  @@index([warrantyId])
  @@index([userId])
  @@index([status])
  @@index([isFraud])
}

model ClaimLog {
  id        String      @id @default(cuid())
  claimId   String
  status    ClaimStatus
  note      String?     @db.Text
  changedBy String?     // adminId or userId
  createdAt DateTime    @default(now())

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
}

model WarrantyEvent {
  id         String    @id @default(cuid())
  warrantyId String
  type       EventType
  txHash     String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])

  @@index([warrantyId])
  @@index([type])
  @@index([createdAt])
}

//////////////////////////////////////////////////////
// 📜 AUDIT SYSTEM
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?  // id of the record affected
  details   String?  @db.Text
  txHash    String?
  ipAddress String?  // admin IP for security
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@index([entityId])
}

//////////////////////////////////////////////////////
// 📊 ENUMS
//////////////////////////////////////////////////////

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
}

enum ClaimType {
  REPAIR
  REPLACEMENT
  REFUND
}

enum EventType {
  CREATED
  TRANSFERRED
  CLAIM_INITIATED
  CLAIM_APPROVED
  CLAIM_REJECTED
  EXPIRED
  VOIDED
}
