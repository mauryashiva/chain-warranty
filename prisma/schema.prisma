generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 👤 USER & AUTHENTICATION
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  // Profile info from registration
  name  String?
  email String? @unique
  phone String?

  wallets    Wallet[]
  claims     Claim[]
  warranties WarrantyOwnership[]

  sentTransfers     Transfer[] @relation("FromUser")
  receivedTransfers Transfer[] @relation("ToUser")

  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  userId    String
  createdAt DateTime @default(now())

  // 🔥 Industry Fix: Added Cascade Delete so no orphan wallets remain if a User is removed
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([address])
}

//////////////////////////////////////////////////////
// 🔐 ADMIN & RBAC SYSTEM
//////////////////////////////////////////////////////

model Admin {
  id        String      @id @default(cuid())
  wallet    String      @unique // The primary identifier for SIWE (MetaMask login)
  name      String
  email     String      @unique
  role      AdminRole   @default(CLAIMS_AGENT)
  status    AdminStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime    @default(now())

  auditLogs AuditLog[]
}

enum AdminRole {
  SUPER_ADMIN // Can do everything
  BRAND_MANAGER // Manages Brands & Products
  CLAIMS_AGENT // Only reviews and resolves claims
  RETAILER_MANAGER // Manages Retailer list
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  REVOKED
}

//////////////////////////////////////////////////////
// 🏢 BUSINESS ENTITIES & CATALOG
//////////////////////////////////////////////////////

model Company {
  id        String    @id @default(cuid())
  name      String
  website   String?
  createdAt DateTime  @default(now())
  isDeleted Boolean   @default(false)
  products  Product[]
}

model Brand {
  id      String @id @default(cuid())
  name    String @unique
  slug    String @unique
  country String
  status  String @default("Active")

  // 🔥 New Premium UI Fields
  website      String?
  supportEmail String?
  supportPhone String?
  taxId        String?
  logoUrl      String?
  description  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  products Product[]
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  category    String?
  subCategory String?
  sku         String? @unique

  // Pricing & Warranty Specs mapped from Controller
  warrantyPeriod String?
  priceMin       Float?
  priceMax       Float?
  currency       String? @default("USD")

  // Manufacturing & Compliance Metadata
  launchDate         DateTime?
  manufactureCountry String?
  hsnCode            String?
  variants           String? // Comma separated list
  serialRegex        String?
  termsUrl           String?
  status             String    @default("Active")

  companyId String
  brandId   String? // Link to the Brand model
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  company    Company    @relation(fields: [companyId], references: [id])
  brand      Brand?     @relation(fields: [brandId], references: [id])
  warranties Warranty[]
  serials    Serial[]

  @@index([companyId])
  @@index([brandId])
}

model Serial {
  id           String       @id @default(cuid())
  number       String       @unique
  productId    String
  batch        String?
  mfgDate      DateTime
  retailerName String?
  status       SerialStatus @default(UNREGISTERED)
  registeredBy String? // Wallet address if registered

  product Product @relation(fields: [productId], references: [id])
}

enum SerialStatus {
  UNREGISTERED
  REGISTERED
  FLAGGED
}

//////////////////////////////////////////////////////
// 🧾 WARRANTY CORE (BLOCKCHAIN LINKED)
//////////////////////////////////////////////////////

model Warranty {
  id              String @id @default(cuid())
  tokenId         String @unique
  contractAddress String

  // Data captured from Step 01 & 03
  productName      String?
  brand            String?
  serialNumber     String?
  imei             String?
  category         String?
  color            String?
  productCondition String?

  // Purchase Details
  purchaseDate   DateTime
  warrantyPeriod String?
  expiryDate     DateTime

  // 🔥 Industry Fix: Decimal for currency accuracy
  price Decimal? @db.Decimal(10, 2)

  retailer      String?
  invoiceNumber String?
  country       String?

  // Original Registrant Info (Snapshot)
  ownerName  String?
  ownerEmail String?
  ownerPhone String?

  // Cloud Storage Links (Supabase URLs)
  frontPhotoUrl   String?
  backPhotoUrl    String?
  invoiceDocUrl   String?
  warrantyCardUrl String?

  status    WarrantyStatus @default(ACTIVE)
  qrCodeUrl String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Relations
  ownerships WarrantyOwnership[]
  claims     Claim[]
  events     WarrantyEvent[]
  transfers  Transfer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  @@index([tokenId])
  @@index([brand, serialNumber])
  @@index([ownerEmail])
}

//////////////////////////////////////////////////////
// 👑 OWNERSHIP & TRANSFERS
//////////////////////////////////////////////////////

model WarrantyOwnership {
  id         String   @id @default(cuid())
  warrantyId String
  userId     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([warrantyId, userId])
  @@index([warrantyId])
  @@index([userId])
}

model Transfer {
  id         String   @id @default(cuid())
  warrantyId String
  fromUserId String
  toUserId   String
  txHash     String   @unique
  createdAt  DateTime @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])
  fromUser User     @relation("FromUser", fields: [fromUserId], references: [id])
  toUser   User     @relation("ToUser", fields: [toUserId], references: [id])

  @@index([warrantyId])
  @@index([txHash])
}

//////////////////////////////////////////////////////
// 🛠️ CLAIM SYSTEM
//////////////////////////////////////////////////////

model Claim {
  id         String      @id @default(cuid())
  warrantyId String
  userId     String
  type       ClaimType
  status     ClaimStatus @default(PENDING)
  reason     String?
  fraudScore Float?
  isFraud    Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  warranty Warranty   @relation(fields: [warrantyId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  logs     ClaimLog[]

  @@index([warrantyId])
  @@index([userId])
}

model ClaimLog {
  id        String      @id @default(cuid())
  claimId   String
  status    ClaimStatus
  note      String?
  createdAt DateTime    @default(now())

  claim Claim @relation(fields: [claimId], references: [id])
}

model WarrantyEvent {
  id         String    @id @default(cuid())
  warrantyId String
  type       EventType
  txHash     String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  warranty Warranty @relation(fields: [warrantyId], references: [id])

  @@index([warrantyId])
}

//////////////////////////////////////////////////////
// 📜 AUDIT SYSTEM
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String // e.g., "PRODUCT_ADDED"
  entity    String // e.g., "WH-1000XM5"
  details   String? // JSON string of changes
  txHash    String? // If the action was on-chain
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id])
}

//////////////////////////////////////////////////////
// 📊 ENUMS
//////////////////////////////////////////////////////

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
}

enum ClaimType {
  REPAIR
  REPLACEMENT
  REFUND
}

enum EventType {
  CREATED
  TRANSFERRED
  CLAIM_INITIATED
  CLAIM_APPROVED
  CLAIM_REJECTED
  EXPIRED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
}
